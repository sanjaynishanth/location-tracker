# Copy this file to .env and change the values

# Shared secret. The mobile app and the dashboard must send this
# in the X-API-Key header. CHANGE IT before exposing to the internet.
API_KEY=change-me-please

# Optional: point to Postgres later, e.g.
# DATABASE_URL=postgresql://user:pass@host:5432/tracker
# Default is a local SQLite file (perfect for testing).
# DATABASE_URL=sqlite:///./tracker.db
